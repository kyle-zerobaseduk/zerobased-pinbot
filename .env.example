# Pinterest API Token
# Get from: https://developers.pinterest.com/apps
PINTEREST_TOKEN=your_pinterest_token_here

# Anthropic API Key
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_key_here

# Dashboard Password (change this!)
DASHBOARD_PASSWORD=change-me-to-something-secure

# Timezone (default: Europe/London)
TZ=Europe/London

# AI Model (default: claude-haiku-4-5-20251001)
AI_MODEL=claude-haiku-4-5-20251001

# Data directory (default: ./data)
# For Railway deployment, use: /data
DATA_DIR=./data

# Server port (Railway sets automatically)
PORT=3000

# Node environment
NODE_ENV=production
